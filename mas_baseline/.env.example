# ─────────────────────────────────────────────────────────────────────────────
# MAS Baseline — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: none | anthropic | openai | groq | local_ollama
# "none" = fully deterministic / rule-based (no LLM calls, works out of the box)
LLM_PROVIDER=none

# ── Model override (optional) ─────────────────────────────────────────────────
# If blank, a sensible default is used for the chosen provider:
#   anthropic    → claude-3-haiku-20240307
#   openai       → gpt-4o-mini
#   groq         → llama3-8b-8192
#   local_ollama → llama3
LLM_MODEL=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# ── Groq ─────────────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=groq
# Free tier available at: https://console.groq.com
GROQ_API_KEY=

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=local_ollama
# Install Ollama from: https://ollama.com
# Then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
